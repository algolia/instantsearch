exports[`generator: schema-driven widgets (JS flavor) snapshot: Hits.js 1`] = `
"import { hits } from 'instantsearch.js/es/widgets';

export function Hits(container) {
  return hits({
    container,
    templates: {
      item: (hit, { html }) => html\`
        <article>
          <img src=\\"\${hit.image_url}\\" alt=\\"\${hit.name}\\" />
          <h3>\${hit.name}</h3>
          <p>\${hit.description}</p>
        </article>
      \`,
    },
  });
}
"
`;

