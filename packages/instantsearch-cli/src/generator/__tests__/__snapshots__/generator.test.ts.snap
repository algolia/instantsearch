"import { sortBy } from 'instantsearch.js/es/widgets';

const items = [
  { value: \\"products\\", label: \\"Featured\\" },
  { value: \\"products_price_asc\\", label: \\"price asc\\" },
  { value: \\"products_price_desc\\", label: \\"price desc\\" },
];

export function SortBy(container) {
  return sortBy({ container, items });
}
"
`;

exports[`generator: schema-driven widgets (React + TypeScript) snapshot: Hits.tsx 1`] = `
"import { Hits as InstantSearchHits } from 'react-instantsearch';

type HitRecord = {
  name: string;
  image_url: string;
  description: string;
};

function Hit({ hit }: { hit: HitRecord }) {
  return (
    <article>
      <img src={hit.image_url} alt={hit.name} />
      <h3>{hit.name}</h3>
      <p>{hit.description}</p>
    </article>
  );
}

export function Hits() {
  return <InstantSearchHits<HitRecord> hitComponent={Hit} />;
}
"
`;

